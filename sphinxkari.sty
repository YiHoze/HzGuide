% admonition ------------------------------------------------------------------
\ExplSyntaxOn
\DeclareDocumentEnvironment {sphinxadmonition} { mm }
{   
    \str_set:Nx \l_tmpa_str { #2 }
    \str_remove_all:Nn \l_tmpa_str {:}
    \begin{note}(\l_tmpa_str)
}{
    \end{note}
}

\RenewTColorBox{ShadeBox}{ s O{} }
{
    before~skip=0pt, after~skip=0pt,
    boxrule=0.75pt, colframe=white, colback=backgray, arc=0.5ex,
    boxsep=0ex, top=0.75ex, bottom=0.75ex, left=0.5em, right=0.5em,
    titlerule=0.75pt, toptitle=0.5ex, bottomtitle=0.5ex,
    colbacktitle=lightgray, coltitle=black,
    fonttitle=\l_bbox_title_font_tl, title=#2,
	IfBooleanTF={#1}{
		breakable=\l_bbox_breakable_adhoc_tl
	}{
		breakable=\l_bbox_breakable_default_tl
	}
}
\ExplSyntaxOff

\RenewBoundedBox{reference}{
    signal={}, 
    style=\raggedright,
    font=\ttfamily\small,
    breakable-default = true
}

% literal ---------------------------------------------------------------------
{\catcode`\ =\active\gdef\vobeyspaces{\catcode`\ =\active\let =\@xobeysp}}
\def\@xobeysp{\penalty\z@\mbox{}\space\penalty\z@}
{\catcode`\^^M=\active\gdef\vobeylines{\catcode`\^^M=\active\let^^M=\x@vobeylines}}
\def\x@vobeylines{\par\leavevmode\relax}

\renewcommand*\sphinxafterbreak{\spx@opt@verbatimcontinued}
\DeclareDocumentEnvironment {sphinxVerbatim} { o }
{  
    \begin{reference}
    \setSpacing{1}
    \sphinxbreaksatspecials    
    \sphinxbreaksviaactive    
    \vobeyspaces
    \vobeylines
}{
    \vspace{-\baselineskip}
    \end{reference}
}

