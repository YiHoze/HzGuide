\tl_new:N \SphinxImageScale
\NewDocumentCommand \SetImageScale { m }
{
    \tl_set:Nn \ImageScale{#1}
}
\SetImageScale{0.8}

\cs_set_eq:NN \OrgIncludegraphics \includegraphics
\DeclareDocumentCommand \includegraphics { o m }
{
  \tl_set:Nn \l_tmpa_tl {#2}
  %\tl_replace_once:Nnn \l_tmpa_tl {.svg}{.pdf}
  \hbox_set:Nn \l_image_box{
      \OrgIncludegraphics[scale=\ImageScale]{\l_tmpa_tl}
  }
  \dim_set_towidth:Nn \l_tmpa_dim { \box_use:N \l_image_box }
  \dim_compare:nTF { \l_tmpa_dim > \linewidth }
  {
    \OrgIncludegraphics[width=\linewidth]{\l_tmpa_tl}
  }{
    \object_locate:N \l_tmpa_dim
    \box_use:N \l_image_box
  }
}

\DeclareDocumentCommand \adjustimage { m m }
{
    \includegraphics{#2}
}

\NewDocumentCommand \MakeTitle {}
{
    \tl_if_empty:NF \@title { \maketitle }
}

