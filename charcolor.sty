% written by Yi, Hoze
\ProvidesPackage{charcolor}[2019/02/19]

\RequirePackage{expl3}
\RequirePackage{kotex}
\RequirePackage{tikz}
\ExplSyntaxOn
\sys_if_engine_luatex:T
{
	\usepackage{colorjamo} % https://github.com/dohyunkim/colorjamo
}
\ExplSyntaxOff
\usepackage{environ}

% These font options are required to colorize hangul consonants and vowels using LuaLaTeX
%\setmainhangulfont[Script=Hangul,Language=Korean]{HCR Batang}

\ExplSyntaxOn
\int_new:N \l_incr_int
\tl_new:N \l_R_tl
\tl_new:N \l_G_tl
\tl_new:N \l_B_tl
\int_new:N \l_R_int
\int_new:N \l_G_int
\int_new:N \l_B_int

\keys_define:nn { CharColor }
{
	min 			.tl_set:N = 	\l_charcolor_rand_min_tl, 
	max 			.tl_set:N = 	\l_charcolor_rand_max_tl, 
	ball			.bool_set:N = 	\l_charcolor_ball_bool,
	ballfont		.tl_set:N = 	\l_charcolor_ball_font_tl,
	gradient		.bool_set:N = 	\l_charcolor_gradient_bool,
	RGB				.tl_set:N = 	\l_charcolor_gradient_RGB_tl, % hexadecimal	
	step			.int_set:N = 	\l_charcolor_gradient_step_int,
	cont			.bool_set:N = 	\l_charcolor_gradient_cont_bool,	
	initial			.bool_set:N =	\l_charcolor_initial_emph_bool,
	inicolor		.tl_set:N = 	\l_charcolor_ini_tl,
	inifont			.tl_set:N = 	\l_charcolor_ini_font_tl
}
\NewDocumentCommand \CharColorSet { s m }
{
	\keys_set:nn { CharColor }{ #2 }
	\IfBooleanT { #1 }
	{
		\charcolor_RGB_initialize:
	}
}
\cs_new:Nn \charcolor_RGB_initialize:
{			
	\tl_set:Nx \l_R_tl { \str_range:Nnn \l_charcolor_gradient_RGB_tl { 1 }{ 2 } }
	\tl_set:Nx \l_G_tl { \str_range:Nnn \l_charcolor_gradient_RGB_tl { 3 }{ 4 } }
	\tl_set:Nx \l_B_tl { \str_range:Nnn \l_charcolor_gradient_RGB_tl { 5 }{ 6 } }		
	\int_set:Nn \l_R_int { \exp_args:No \int_from_hex:n { \l_R_tl } }
	\int_set:Nn \l_G_int { \exp_args:No \int_from_hex:n { \l_G_tl } }
	\int_set:Nn \l_B_int { \exp_args:No \int_from_hex:n { \l_B_tl } }		
	\int_set_eq:NN \l_incr_int \l_charcolor_gradient_step_int
}
\CharColorSet*{
	min=0, % must be greater than or equal to 0
	max=255, % must be less than or equal to 255
	ball=false,
	ballfont=\sffamily\bfseries,
	gradient=false,
	RGB=FF0000,
	step=5,
	cont=false,	% continue from the previous gradation color 
	initial=false,
	inicolor=orange,
	inifont=\bfseries
}

% \charcolor*|+[options]{text}
% charcol / \charcolor colorizes hangul consonants and vowels by random using LuaLaTeX. XeLaTeX colorizes characters.
% charball / \charcolor* puts characters in randomly colored balls.
% charini / \charcolor| emphasizes initials in the specified font and color.
% chargrad / \charcolor+ colorizes characters by gradation.
% charballgrad / \charcolor*+ puts characters in gradiently colored balls.
% charinigrad / \charcolor|+ emphasizes initials in gradient colors.
\NewDocumentCommand \charcolor { s t| t+ o +m }
{	
	\group_begin:
	\IfValueT { #4 }
	{
		\keys_set:nn { CharColor }{ #4 }
	}
	\IfBooleanTF { #1 }
	{
		\bool_set_true:N \l_charcolor_ball_bool
	}{
		\bool_set_false:N \l_charcolor_ball_bool
	}
	\IfBooleanTF { #2 }
	{
		\bool_set_true:N \l_charcolor_initial_emph_bool
	}{
		\bool_set_false:N \l_charcolor_initial_emph_bool
	}	
	\IfBooleanTF { #3 }
	{
		\bool_set_true:N \l_charcolor_gradient_bool
		\bool_if:NF \l_charcolor_gradient_cont_bool
		{
			\charcolor_RGB_initialize:
		}
	}{
		\bool_set_false:N \l_charcolor_gradient_bool
	}	
	\seq_set_split:Nnn \l_tmpa_seq { \par }{ #5 }
	\seq_map_function:NN \l_tmpa_seq \charcolor_split_lines:n	
	\group_end:
}
\int_new:N \l_seq_count_int
\cs_new:Npn \charcolor_split_lines:n #1
{
	\seq_set_split:Nnn \l_tmpb_seq { \\ }{ #1 }	
	\int_set:Nn \l_seq_count_int { \seq_count:N \l_tmpb_seq }
	\seq_map_inline:Nn \l_tmpb_seq
	{
		\seq_set_split:Nnn \l_tmpc_seq { ~ }{ ##1 }
		\bool_if:NTF \l_charcolor_initial_emph_bool 
		{
			\seq_map_function:NN \l_tmpc_seq \charcolor_emph_initial:n
		}{
			\seq_map_function:NN \l_tmpc_seq \charcolor_split_words:n
		}
		\int_decr:N \l_seq_count_int
		\int_compare:nT { \l_seq_count_int > 0 }
		{
			\newline
		}
	}\par
}
\cs_new:Npn \charcolor_split_words:n #1
{
	\tl_set:Nn \l_tmpc_tl { #1 }
	\tl_map_inline:Nn \l_tmpc_tl
	{
		\charcolor_assign_color:
		\bool_if:NTF \l_charcolor_ball_bool
		{
			\CharBall{##1}\hspace{0pt}
		}{
			\bool_if:NTF \l_charcolor_gradient_bool
			{
				\textcolor{char}{##1}
			}{
				\sys_if_engine_xetex:TF	
				{
					\textcolor{char}{##1}
				}{					
					\begin{colorjamo}
						\textcolor{char}{##1}
					\end{colorjamo}
				}
			}
		}
		\allowbreak
	}
	\bool_if:NTF \l_charcolor_ball_bool
	{
		\space\space
	}{
		\space
	}
}
\cs_new:Npn \charcolor_emph_initial:n #1
{
	\str_set:Nx \l_tmpa_str { \str_head:n {#1} }
	\str_set:Nx \l_tmpb_str { \str_tail:n {#1} }
	\bool_if:NTF \l_charcolor_gradient_bool 
	{
		\charcolor_assign_grad:
		\textcolor{char}{\l_charcolor_ini_font_tl\l_tmpa_str}
	}{
		\textcolor{\l_charcolor_ini_tl}{\l_charcolor_ini_font_tl\l_tmpa_str}
	}
	\l_tmpb_str\space
}
\cs_new:Nn \charcolor_assign_color: 
{	
	\bool_if:NTF \l_charcolor_ball_bool	
	{
		\bool_if:NTF \l_charcolor_gradient_bool
		{
			\charcolor_assign_grad:
		}{
			\charcolor_assign_rand:
		}
		\charcolor_complementary:N \l_R_tl
		\charcolor_complementary:N \l_G_tl
		\charcolor_complementary:N \l_B_tl
		\definecolor{char}{RGB}{\l_R_tl, \l_G_tl, \l_B_tl}		
	}{
		\bool_if:NTF \l_charcolor_gradient_bool
		{
			\charcolor_assign_grad:
		}{
			\charcolor_assign_rand:
			\sys_if_engine_luatex:T
			{
				\charcolor_assign_rand_hex:N \jamocolorcho 
				\charcolor_assign_rand_hex:N \jamocolorjung
				\charcolor_assign_rand_hex:N \jamocolorjong
			}
		}
	}
}
\cs_new:Nn \charcolor_assign_grad:
{
	\tl_set:Nx \l_R_tl { \int_use:N \l_R_int } 
	\tl_set:Nx \l_G_tl { \int_use:N \l_G_int } 
	\tl_set:Nx \l_B_tl { \int_use:N \l_B_int }	
	\bool_if:NTF \l_charcolor_ball_bool	
	{
		\definecolor{ball}{RGB}{\l_R_tl, \l_G_tl, \l_B_tl}
	}{
		\definecolor{char}{RGB}{\l_R_tl, \l_G_tl, \l_B_tl}
	}
	\charcolor_grad_incr:N \l_R_int
	\charcolor_grad_incr:N \l_G_int
	\charcolor_grad_incr:N \l_B_int
}
\cs_new:Nn \charcolor_assign_rand:
{
	\charcolor_assign_rand_dec:N \l_R_tl
	\charcolor_assign_rand_dec:N \l_G_tl
	\charcolor_assign_rand_dec:N \l_B_tl
	\bool_if:NTF \l_charcolor_ball_bool	
	{
		\definecolor{ball}{RGB}{\l_R_tl, \l_G_tl, \l_B_tl}
	}{
		\definecolor{char}{RGB}{\l_R_tl, \l_G_tl, \l_B_tl}
	}
}
\cs_new:Npn \charcolor_complementary:N #1 
{
	\exp_args:NNx \int_set:Nn \l_tmpa_int { 255 - #1 }
	\tl_set:Nx #1 { \int_use:N \l_tmpa_int }	
}
\cs_new:Npn \charcolor_grad_incr:N #1
{
	\int_gadd:Nn #1 { \l_incr_int }
	\int_compare:nT { #1 > 255}
	{
		\int_gset:Nn \l_incr_int { \l_charcolor_gradient_step_int * -1 }
		\int_gset:Nn #1 { 255 }
	}
	\int_compare:nT { #1 < 0}
	{
		\int_gset:Nn \l_incr_int { \l_charcolor_gradient_step_int }
		\int_gset:Nn #1 { 0 }
	}	
}
\cs_new:Npn \charcolor_assign_rand_hex:N #1
{	
	\tl_clear:N \l_tmpa_tl	
	\int_step_inline:nnnn {1}{1}{3}
	{

		\tl_set:Nx \l_tmpb_tl { \int_to_Hex:n { \int_rand:nn {\l_charcolor_rand_min_tl}{\l_charcolor_rand_max_tl} }}
		\exp_args:NNx \int_set:Nn \l_tmpb_int { \tl_count:N \l_tmpb_tl }
		\int_compare:nT { \l_tmpb_int == 1 }
		{
			\tl_put_right:Nn \l_tmpb_tl { 0 }
			\tl_reverse:N \l_tmpb_tl
		}
		\tl_put_right:Nx \l_tmpa_tl { \l_tmpb_tl }
	}
	\exp_args:No #1 { \l_tmpa_tl }	
} 
\cs_new:Npn \charcolor_assign_rand_dec:N #1
{	
	\pgfmathparse { random (\l_charcolor_rand_min_tl, \l_charcolor_rand_max_tl) }
	\tl_set:No #1 \pgfmathresult
}
\NewDocumentCommand \CharBall { m }
{
	\tikz\node[
		circle,shade,draw=white,thin,inner~sep=1pt,
		ball~color=ball,
		text~width=1em,
		font=\l_charcolor_ball_font_tl,text~badly~centered
	]{\textcolor{char}{#1}};
}
\NewEnviron{charcol}[1][]
{
	\group_begin:
	\keys_set:nn { CharColor }{ #1 }
	\exp_args:No\charcolor{\BODY}
	\group_end:
}
\NewEnviron{charball}[1][]
{
	\group_begin:
	\keys_set:nn { CharColor }{ #1 }
	\exp_args:NNo\charcolor*{\BODY}
	\group_end:
}
\NewEnviron{charini}[1][]
{
	\group_begin:
	\keys_set:nn { CharColor }{ #1 }
	\exp_args:NNo\charcolor|{\BODY}
	\group_end:
}
\NewEnviron{chargrad}[1][]
{
	\group_begin:
	\keys_set:nn { CharColor }{ #1 }
	\exp_args:NNo\charcolor+{\BODY}
	\group_end:
}
\NewEnviron{charballgrad}[1][]
{
	\group_begin:
	\keys_set:nn { CharColor }{ #1 }
	\exp_args:NNNo\charcolor*+{\BODY}
	\group_end:
}
\NewEnviron{charinigrad}[1][]
{
	\group_begin:
	\keys_set:nn { CharColor }{ #1 }
	\exp_args:NNNo\charcolor|+{\BODY}
	\group_end:
}
\ExplSyntaxOff
\endinput